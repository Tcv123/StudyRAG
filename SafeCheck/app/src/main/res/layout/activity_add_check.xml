<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="New Safety Check"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etVehicleReg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Vehicle Registration (e.g. AB12 CDE)"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etDriverName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Driver Name"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Overall Status:"
            android:textSize="16sp"
            android:layout_marginBottom="4dp"/>

        <RadioGroup
            android:id="@+id/rgStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbPass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pass"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rbFail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fail"/>
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Defects:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etDefectDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Defect description (e.g. Cracked Mirror)"
            android:inputType="text"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerSeverity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnAddDefect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Defect to List"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPendingDefects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSaveCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Safety Check"/>

    </LinearLayout>
</ScrollView>
