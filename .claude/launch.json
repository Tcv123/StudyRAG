{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "npx serve (static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--no-clipboard"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Python HTTP server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server"],
      "port": 8000,
      "autoPort": true
    }
  ]
}
